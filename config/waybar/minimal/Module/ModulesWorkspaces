	"on-scroll-down": "hyprctl dispatch workspace e-1",
	"persistent-workspaces": { "*": 5 },
	"format": "{icon}",
	"format-icons": {
		"active": "<span font='12'>󰮯</span>",
		"empty": "<span font='8'></span>",
		"default": "󰊠"
	}
},

// ── Alphabet style ────────────────────────────────────────────────────────────
