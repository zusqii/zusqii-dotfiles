	"on-scroll-down": "hyprctl dispatch workspace e-1",
	"persistent-workspaces": { "*": 5 },
	"format-icons": {
		"1": "I", "2": "II", "3": "III", "4": "IV", "5": "V",
		"6": "VI", "7": "VII", "8": "VIII", "9": "IX", "10": "X"
	}
},

// ── Pac-Man style ─────────────────────────────────────────────────────────────
